DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional future providers
OPENAI_API_KEY=
TUSHARE_TOKEN=

# QQ Mail SMTP for email reports and alerts
# 1. QQ邮箱设置 -> 账户 -> 开启 SMTP 服务
# 2. 使用“授权码”作为 SMTP_PASSWORD，不要填写 QQ 登录密码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=your_qq_mail@qq.com
SMTP_PASSWORD=your_qq_mail_smtp_authorization_code
SMTP_FROM=your_qq_mail@qq.com
SMTP_FROM_NAME=SgodAI Market Radar
SMTP_TIMEOUT_SECONDS=20
